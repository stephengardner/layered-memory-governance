# Copy to .env and fill in. .env is gitignored; .env.example is the
# template committed to the repo so contributors know what's expected.

# Telegram Notifier (Phase 37): create a bot via @BotFather, paste the token.
TELEGRAM_BOT_TOKEN=

# Your Telegram chat id for escalation delivery.
TELEGRAM_CHAT_ID=

# Personal access token for the `layered-autonomous-governance` machine-user
# account. Required by scripts/cr-trigger.mjs (the canonical CodeRabbit
# trigger path per dev-cr-triggers-via-machine-user) and by
# scripts/run-pr-landing.mjs. CodeRabbit's @-mention anti-loop ignores
# GitHub App / [bot] mentions, so the trigger comment must be authored by
# a User-type account; the machine user is the dedicated account for that.
#
# How to get it: as the operator who controls the
# layered-autonomous-governance user, log in to that account on github.com,
# create a fine-grained PAT with `Pull requests: read+write` and
# `Issues: read+write` scoped to this repo, paste below. Source via
# `set -a && . .env && set +a` before running any script that reads this
# variable.
LAG_OPS_PAT=

# Operator principal id used by intend.mjs / run-cto-actor.mjs / decide.mjs
# and by the operator-session-pulse hooks. The principal record must
# exist under .lag/principals/<id>.json. Default-deny: if unset, every
# script that needs it exits with a clear error rather than guessing.
# For this repo, set to apex-agent (the canonical operator principal
# whose record at .lag/principals/apex-agent.json carries the signing
# authority for L3 canon writes). Other deployments name their own.
LAG_OPERATOR_ID=apex-agent

# Override (optional): bot role whose App credentials at
# <stateDir>/apps/<role>.json drive the autonomous dispatch path
# (intent -> deep planning pipeline -> code-author -> PR).
#
# Resolution ladder used by scripts/invokers/autonomous-dispatch.mjs
# (in priority order):
#   1. LAG_DISPATCH_BOT_ROLE env (this var)  -- one-shot operator override
#   2. canon pol-dispatch-invoker-default atom -- deployment default
#   3. FALLBACK_DISPATCH_ROLE constant -- hardcoded 'lag-ceo' fallback
#
# Leaving this unset is the substrate-pure path: the canon atom (rung 2)
# is the source of truth for this deployment's role and the registrar
# resolves it via readDispatchInvokerDefaultPolicy. Set this var only
# when running under a non-default bot for a one-shot dispatch.
# Distinct from LAG_DISPATCH_PRINCIPAL_ID which is the executor-side
# identity (defaults to role for back-compat).
# LAG_DISPATCH_BOT_ROLE=

# Override (optional): pipeline mode for intend.mjs --trigger spawns.
#
# Resolution ladder used by scripts/intend.mjs (in priority order):
#   1. LAG_PIPELINE_MODE env (this var) -- one-shot operator override
#   2. canon pol-planning-pipeline-default-mode atom -- deployment default
#   3. FALLBACK_PIPELINE_MODE constant -- hardcoded 'substrate-deep' fallback
#
# Valid values: 'single-pass' | 'substrate-deep'. Leaving this unset is
# the substrate-pure path: the canon atom (rung 2) is the source of
# truth for this deployment's default mode. Set this var only when
# running a one-shot under a non-default mode (e.g. LAG_PIPELINE_MODE=
# single-pass node scripts/intend.mjs --trigger for a fast typo fix
# when canon default is substrate-deep).
# LAG_PIPELINE_MODE=

# Owner/repo slug for the PR-orphan reconcile pass run by
# `lag-run-loop --reconcile-pr-orphans` (and any other script that
# resolves the current GitHub repo via bin/lag-run-loop.js's
# resolveOwnerRepo helper). When unset, the helper falls back to
# `gh repo view`; when the fallback also fails (running outside a
# checkout, gh auth not configured), the orphan-reconcile pass
# silent-skips with a single-line WARN. Set this in non-checkout
# deployments (containers, CI runners) where `gh repo view` cannot
# resolve. Format: owner/repo (e.g. acme-org/lag-deployment).
GH_REPO=
