# Copy to .env and fill in. .env is gitignored; .env.example is the
# template committed to the repo so contributors know what's expected.

# Telegram Notifier (Phase 37): create a bot via @BotFather, paste the token.
TELEGRAM_BOT_TOKEN=

# Your Telegram chat id for escalation delivery.
TELEGRAM_CHAT_ID=

# Personal access token for the `layered-autonomous-governance` machine-user
# account. Required by scripts/cr-trigger.mjs (the canonical CodeRabbit
# trigger path per dev-cr-triggers-via-machine-user) and by
# scripts/run-pr-landing.mjs. CodeRabbit's @-mention anti-loop ignores
# GitHub App / [bot] mentions, so the trigger comment must be authored by
# a User-type account; the machine user is the dedicated account for that.
#
# How to get it: as the operator who controls the
# layered-autonomous-governance user, log in to that account on github.com,
# create a fine-grained PAT with `Pull requests: read+write` and
# `Issues: read+write` scoped to this repo, paste below. Source via
# `set -a && . .env && set +a` before running any script that reads this
# variable.
LAG_OPS_PAT=

# Operator principal id used by intend.mjs / run-cto-actor.mjs / decide.mjs
# and by the operator-session-pulse hooks. The principal record must
# exist under .lag/principals/<id>.json. Default-deny: if unset, every
# script that needs it exits with a clear error rather than guessing.
LAG_OPERATOR_ID=

# Bot role whose App credentials at <stateDir>/apps/<role>.json drive
# the autonomous dispatch path (intent -> deep planning pipeline ->
# code-author -> PR). Required by scripts/invokers/autonomous-dispatch.mjs
# (the canonical SubActorRegistry registrar that intend.mjs --trigger
# defaults to). Without it, autonomous-solve intents fail-loud at
# dispatch-stage register time. In this repo the default role is
# lag-ceo because it already lands code-author PRs; deployments that
# provision a dedicated lag-code-author role can swap by setting this
# variable. Distinct from LAG_DISPATCH_PRINCIPAL_ID which is the
# executor-side identity (defaults to role for back-compat).
LAG_DISPATCH_BOT_ROLE=
