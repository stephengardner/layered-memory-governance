{
  "$schema": "https://claude.ai/schemas/settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/seed-canon-on-session.mjs" },
          { "type": "command", "command": "node .claude/hooks/enforce-lag-ceo-for-gh.mjs" },
          { "type": "command", "command": "node .claude/hooks/enforce-pr-status-composite.mjs" }
        ]
      },
      {
        "matcher": "mcp__github__.*",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/enforce-lag-ceo-for-gh.mjs" }
        ]
      }
    ]
  }
}
