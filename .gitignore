# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*~

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Node
node_modules/
dist/
coverage/
.vitest-cache/
*.tsbuildinfo

# Playwright
test-results/
playwright-report/
.playwright-mcp/
playwright/.cache/

# Simulation scratch
/scratch/
*.sim.log
*.sim.json

# Local palace data (if we test against a real palace)
/.palace/

# LAG self-bootstrap runtime state (atoms, audit log, notifier queue, etc).
# The rendered CLAUDE.md is committed; this directory is the state that
# produces it, gitignored so the repo stays portable.
/.lag/

# Local CTO actor run logs (operational, not repo state).
/.cto-runs/

# Local harness lockfiles.
/.claude/scheduled_tasks.lock

# Per-operator Claude Code settings (opt-in hooks, local preferences).
# `.claude/settings.json` IS checked in for repo-wide governance rules;
# this entry only ignores the per-operator overlay.
/.claude/settings.local.json

# Secrets. .env holds real tokens; .env.example is the committed template.
.env
.env.local
.env.*.local

# Windows artifacts
NUL

# Worktrees created by the scripts/wt.mjs CLI for isolated parallel work.
# Each .worktrees/<slug>/ is itself a git worktree; contents are the branch,
# not the repo. Ignored so the main checkout's `git status` stays clean and
# no worktree body ever lands in a commit on the wrong branch.
/.worktrees/

# NOTES.md at repo root (or worktree root) is the agent-written handoff doc
# for the current worktree. Ephemeral; never tracked on a branch.
/NOTES.md

# Transient operator working-tree artifacts that accumulate during long
# sessions and otherwise trigger the executor's dirty-worktree gate.
# Each was observed to recur in operator workflow 2026-04-26:
#   - UI screenshots from visual-companion + manual review iterations
#   - Bash crash dumps on Windows
#   - tsc incremental build cache for the examples project
#   - Subagent / brainstorm scratch directories (already isolated by tooling)
#   - One-off CR-reply helper scripts the assistant writes during
#     PR-review cycles; should live in /tmp but historically end up here
#   - The .superpowers/ brainstorm directory (per-session artifacts)
#   - The .claude/sounds + .claude/worktrees subtrees (operator-local)
/*.png
/*.stackdump
/.tsbuildinfo-examples
/.superpowers/
/.claude/sounds/
/.claude/worktrees/
/scripts/reply-and-resolve-pr*.mjs
/scripts/reply-and-resolve-cr.mjs
/apps/console/*.png
