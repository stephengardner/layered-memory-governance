# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*~

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Node
node_modules/
dist/
coverage/
.vitest-cache/
*.tsbuildinfo

# Playwright
test-results/
playwright-report/
.playwright-mcp/
playwright/.cache/

# Simulation scratch
/scratch/
*.sim.log
*.sim.json

# Local palace data (if we test against a real palace)
/.palace/

# LAG self-bootstrap runtime state (atoms, audit log, notifier queue, etc).
# The rendered CLAUDE.md is committed; this directory is the state that
# produces it, gitignored so the repo stays portable.
/.lag/

# Local CTO actor run logs (operational, not repo state).
/.cto-runs/

# Local harness lockfiles.
/.claude/scheduled_tasks.lock

# Per-operator Claude Code settings (opt-in hooks, local preferences).
# `.claude/settings.json` IS checked in for repo-wide governance rules;
# this entry only ignores the per-operator overlay.
/.claude/settings.local.json

# Secrets. .env holds real tokens; .env.example is the committed template.
.env
.env.local
.env.*.local

# Windows artifacts
NUL

# Worktrees created by the scripts/wt.mjs CLI for isolated parallel work.
# Each .worktrees/<slug>/ is itself a git worktree; contents are the branch,
# not the repo. Ignored so the main checkout's `git status` stays clean and
# no worktree body ever lands in a commit on the wrong branch.
/.worktrees/

# NOTES.md at repo root (or worktree root) is the agent-written handoff doc
# for the current worktree. Ephemeral; never tracked on a branch.
/NOTES.md
