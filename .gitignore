# Local palace data (if we test against a real palace)
/.palace/

# LAG self-bootstrap runtime state (atoms, audit log, notifier queue, etc).
# The rendered CLAUDE.md is committed; this directory is the state that
# produces it, gitignored so the repo stays portable.
/.lag/

# Local CTO actor run logs (operational, not repo state).
/.cto-runs/

# Local harness lockfiles.
/.claude/scheduled_tasks.lock

# Per-operator Claude Code settings (opt-in hooks, local preferences).
# `.claude/settings.json` IS checked in for repo-wide governance rules;
# this entry only ignores the per-operator overlay.
/.claude/settings.local.json

# Secrets. .env holds real tokens; .env.example is the committed template.
.env
.env.local
.env.*.local

# Windows artifacts
NUL
